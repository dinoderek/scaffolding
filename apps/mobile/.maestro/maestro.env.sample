# Copy this file to .maestro/maestro.env.local and adjust values per worktree.

TASK_ID="${TASK_ID:-ad-hoc}"

MAESTRO_IOS_SHARED_BUILD_ROOT="${MAESTRO_IOS_SHARED_BUILD_ROOT:-$HOME/.cache/boga/maestro/ios-dev-client}"
MAESTRO_IOS_DEV_CLIENT_APP_PATH="${MAESTRO_IOS_DEV_CLIENT_APP_PATH:-$MAESTRO_IOS_SHARED_BUILD_ROOT/mobile-dev-client.app}"

IOS_SIM_DEVICE="${IOS_SIM_DEVICE:-iPhone 17 Pro}"
IOS_SIM_DEVICE_POOL="${IOS_SIM_DEVICE_POOL:-iPhone 17 Pro,iPhone 17 Pro Max,iPhone Air}"
IOS_SIM_UDID_POOL="${IOS_SIM_UDID_POOL:-}"

EXPO_DEV_SERVER_BASE_PORT="${EXPO_DEV_SERVER_BASE_PORT:-8082}"
EXPO_START_WAIT_SECONDS="${EXPO_START_WAIT_SECONDS:-30}"

MAESTRO_IOS_SLOT_IDS="${MAESTRO_IOS_SLOT_IDS:-slot-1,slot-2,slot-3}"
MAESTRO_IOS_SLOT_WAIT_SECONDS="${MAESTRO_IOS_SLOT_WAIT_SECONDS:-120}"
MAESTRO_IOS_SLOT_POLL_SECONDS="${MAESTRO_IOS_SLOT_POLL_SECONDS:-1}"
MAESTRO_IOS_SLOT_LOCK_ROOT="${MAESTRO_IOS_SLOT_LOCK_ROOT:-/tmp/scaffolding2-maestro-ios-slots}"

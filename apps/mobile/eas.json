{
  "cli": {
    "version": ">= 16.0.1",
    "appVersionSource": "remote"
  },
  "build": {
    "preview": {
      "developmentClient": false,
      "autoIncrement": true,
      "environment": "production",
      "ios": {
        "distribution": "store"
      },
      "env": {
        "APP_ENV": "prod",
        "APP_NAME": "Boga3 Preview",
        "IOS_BUNDLE_ID": "com.phano.boga3.dev"
      }
    },
    "dev": {
      "developmentClient": true,
      "environment": "development",
      "distribution": "internal",
      "env": {
        "APP_ENV": "dev",
        "APP_NAME": "Boga3 Dev",
        "IOS_BUNDLE_ID": "com.phano.boga3.dev"
      }
    },
    "prod": {
      "autoIncrement": true,
      "environment": "production",
      "ios": {
        "distribution": "store"
      },
      "env": {
        "APP_ENV": "prod",
        "APP_NAME": "Boga3",
        "IOS_BUNDLE_ID": "com.phano.boga3"
      }
    }
  },
  "submit": {
    "preview": {
      "ios": {
        "ascAppId": "6766332857",
        "bundleIdentifier": "com.phano.boga3.dev"
      }
    },
    "prod": {
      "ios": {
        "ascAppId": "6766332909",
        "bundleIdentifier": "com.phano.boga3"
      }
    }
  }
}

# Optional overrides for local helper scripts.
# `./scripts/worktree-setup.sh` links `supabase/.env.local` to
# `~/.config/boga/supabase/cli.env` so all local worktrees share the same
# Supabase CLI version.

# Pin or override the CLI used by repo scripts (default matches `supabase/README.md`).
SUPABASE_CLI_VERSION=2.76.15
